---
import Gradient from './Gradient.astro'
import Container from './Container.astro'
const outro = 'Always open to feedback, questions, and making new friends ✽'
---

<section class="footer relative border-t-2 border-black text-white">
  <Container>
    <div class="absolute inset-0 z-[-1] overflow-hidden">
      <Gradient id="footer-gradient" />
    </div>
    <div class="relative px-6 py-2">
      <div class="flex flex-col items-center gap-10">
        <div class="my-20 flex flex-wrap items-center">
          <h2>
            <span class="inline">{outro} </span>
          </h2>
        </div>
        <div
          class="-mt-6 flex w-full flex-col-reverse justify-between sm:flex-row">
          <div class="emphasis flex gap-2">
            <p>Washington DC</p>
            <p id="clock"></p>
          </div>
          <a href="mailto:cielcpark@gmail.com" class="hoverable emphasis link"
            >cielcpark@gmail.com</a
          >
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  var clockElement = document.getElementById('clock')

  function clock() {
    if (clockElement) {
      clockElement.textContent = new Date().toLocaleTimeString()
    }
  }
  setInterval(clock, 1000)
</script>
