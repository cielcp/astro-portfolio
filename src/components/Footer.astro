---
import Container from './Container.astro'
const outro = 'Always open to feedback, questions, and making new friends!'
---

<Container>
  <div class="my-4 flex flex-col items-center gap-10" aria-label="Hero">
    <div class="my-20 flex flex-wrap items-center">
      <h2>
        <span class="inline"
          >{outro}
          <model-viewer
            camera-controls
            alt="A 3D model of a bow"
            poster="../../images/3d/bow.jpg"
            src="../../images/3d/bow.gltf"
            camera-orbit="180deg 2m"
            disable-zoom
            disable-pan
            interaction-prompt="none"
            auto-rotate
            rotation-per-second="30deg">
          </model-viewer>
        </span>
      </h2>
    </div>
    <div class="-mt-6 flex w-full flex-col-reverse justify-between sm:flex-row">
      <div class="flex gap-2">
        <p>Washington DC</p>
        <p id="clock"></p>
      </div>
      <a href="mailto:cielcpark@gmail.com" class="hoverable"
        >cielcpark@gmail.com</a
      >
    </div>
  </div>
</Container>
<script>
  var clockElement = document.getElementById('clock')

  function clock() {
    if (clockElement) {
      clockElement.textContent = new Date().toLocaleTimeString()
    }
  }
  setInterval(clock, 1000)
</script>
