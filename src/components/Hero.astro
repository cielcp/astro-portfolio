---
import Container from '../components/Container.astro'

const intro1 =
  'is a full stack designer with a background in computer science, creating intuitive, engaging, and joyful digital experiences from ideation to implementation.'
const focus =
  'Digital product design, brand design, frontend development, web development'
const fuel = 'Data, creativity, perfectionism, and Korean comfort food'
---

<section class="flex h-[calc(100vh-96px)] flex-col px-10 align-middle">
  <!-- intro div -->
  <div
    class="my-auto w-1/2 flex-col justify-center px-6 sm:max-w-xl md:max-w-2xl lg:max-w-4xl xl:max-w-6xl">
    <h1 class="my-4 mt-12">Ciel Park</h1>
    <p class="subtitle flex items-center justify-center">
      <span class="inline leading-relaxed"
        >{intro1}
        <!--
        <model-viewer
          camera-controls
          alt="A 3D model of a bow"
          poster="../../images/3d/bow.jpg"
          src="../../images/3d/bow.gltf"
          camera-orbit="180deg 2m"
          disable-zoom
          disable-pan
          interaction-prompt="none"
          auto-rotate
          rotation-per-second="30deg">
        </model-viewer>
         -->
      </span>
    </p>
  </div>
  <div class="my-8 flex">
    <!-- focused on div -->
    <div class="flex w-1/2 flex-col gap-4 p-2 px-6">
      <h3>Focused on</h3>
      <p>
        {focus}
      </p>
    </div>
    <!-- fueled by div -->
    <div class="flex w-1/2 flex-col gap-4 p-2 px-6">
      <h3>Fueled by</h3>
      <p>
        {fuel}
      </p>
    </div>
  </div>
</section>
