---
import BaseLayout from '../layouts/BaseLayout.astro'
const { frontmatter } = Astro.props
---

<BaseLayout pageTitle={frontmatter.title}>
  <div
    class="hero-section flex h-screen flex-col items-center justify-center gap-8 px-44 pt-12 text-white">
    <div class="flex gap-8">
      <div class="w-1/2">
        <h1>{frontmatter.title}</h1>
        <p>{frontmatter.description}</p>
      </div>
      <div class="w-1/2">
        <img src={frontmatter.image.url} alt={frontmatter.image.alt} />
      </div>
    </div>
    <table>
      <tr>
        <th>Role</th>
        <th>Timeline</th>
        <th>Team</th>
        <th>Skills</th>
        <th>Tools</th>
      </tr>
      <tr>
        <td>{frontmatter.projectInfo.role}</td>
        <td>{frontmatter.projectInfo.timeline}</td>
        <td>{frontmatter.projectInfo.team}</td>
        <td>{frontmatter.projectInfo.skills}</td>
        <td>{frontmatter.projectInfo.tools}</td>
      </tr>
    </table>
  </div>

  <div class="case-study pb-24">
    <slot />
  </div>
</BaseLayout>
